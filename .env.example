NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/bizreplyai

JWT_ACCESS_SECRET=replace-with-at-least-32-characters
JWT_REFRESH_SECRET=replace-with-at-least-32-characters
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN_DAYS=30

APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# Optional but recommended in production. Without REDIS_URL, the API uses a bounded in-memory cache.
REDIS_URL=
CACHE_MAX_ENTRIES=5000
CACHE_SWEEP_INTERVAL_SECONDS=60

RESEND_API_KEY=
EMAIL_FROM="BizReply AI <noreply@yourdomain.com>"

WHATSAPP_PROVIDER_MODE=mock
ENABLE_DEV_TOOLS=true
MOCK_WHATSAPP_FORCE_FAILURE=false
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=
META_WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=
META_API_VERSION=v20.0

# Keep the current key stable. During rotation, change the key ID/key and retain old keys in the JSON keyring.
WHATSAPP_CREDENTIAL_KEY_ID=primary
WHATSAPP_CREDENTIAL_ENCRYPTION_KEY=
WHATSAPP_CREDENTIAL_DECRYPTION_KEYS=

OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL="Nemotron 3 Ultra"
OPENROUTER_EMBEDDING_MODEL=
OPENROUTER_EMBEDDING_DIMENSIONS=1536
OPENROUTER_FALLBACK_MODELS=
OPENROUTER_TIMEOUT_MS=30000

OPENROUTER_APP_NAME=BizReply AI
OPENROUTER_APP_URL=
AI_REPLY_ENABLED=true
AI_MIN_CONFIDENCE=0.75
AI_AUTO_CONFIRM_MIN_CONFIDENCE=0.85
PREMIUM_APPOINTMENT_AUTO_CONFIRM_ENABLED=false
AI_MAX_CONTEXT_MESSAGES=12
AI_MAX_BUSINESS_CONTEXT_TOKENS=6000

KNOWLEDGE_BASIC_ASSET_LIMIT=5
KNOWLEDGE_PLUS_ASSET_LIMIT=50
KNOWLEDGE_PREMIUM_ASSET_LIMIT=200
KNOWLEDGE_BASIC_AI_DRAFT_LIMIT=0
KNOWLEDGE_PLUS_AI_DRAFT_LIMIT=20
KNOWLEDGE_PREMIUM_AI_DRAFT_LIMIT=100
KNOWLEDGE_BASIC_PDF_UPLOAD_LIMIT=10
KNOWLEDGE_PLUS_PDF_UPLOAD_LIMIT=50
KNOWLEDGE_PREMIUM_PDF_UPLOAD_LIMIT=250
KNOWLEDGE_BASIC_STORAGE_LIMIT_BYTES=104857600
KNOWLEDGE_PLUS_STORAGE_LIMIT_BYTES=1073741824
KNOWLEDGE_PREMIUM_STORAGE_LIMIT_BYTES=5368709120
KNOWLEDGE_UPLOAD_MAX_BYTES=10485760
KNOWLEDGE_STORAGE_DIR=storage/knowledge
