}

model User {
  id            String        @id @default(cuid())
  firstName     String
  lastName      String
  email         String        @unique
  passwordHash  String
  emailVerified Boolean       @default(false)
  status        UserStatus    @default(ACTIVE)
  accountType   UserAccountType @default(OWNER_CAPABLE)
  canCreateBusiness Boolean   @default(true)
  platformRole  PlatformRole?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  ownedBusinesses              Business[]             @relation("BusinessOwner")
  ownedBusinessAccounts        BusinessAccount[]      @relation("BusinessAccountOwner")
  memberships                  BusinessMember[]       @relation("MemberUser")
  invitedMembers               BusinessMember[]       @relation("MemberInviter")
  sentInvitations              BusinessInvitation[]   @relation("InvitationInviter")
  authTokens                   AuthToken[]
  refreshTokens                RefreshToken[]
  auditLogs                    AuditLog[]
  createdLeads                 Lead[]                 @relation("LeadCreator")
  leadActivities               LeadActivity[]         @relation("LeadActivityActor")
  sentMessages                 Message[]              @relation("MessageSender")
  createdServices              Service[]              @relation("ServiceCreator")
  updatedServices              Service[]              @relation("ServiceUpdater")
  createdAvailability          BusinessAvailability[] @relation("AvailabilityCreator")
  updatedAvailability          BusinessAvailability[] @relation("AvailabilityUpdater")
  createdPolicies              BusinessPolicy[]       @relation("PolicyCreator")
  updatedPolicies              BusinessPolicy[]       @relation("PolicyUpdater")
  createdAppointments          Appointment[]          @relation("AppointmentCreator")
  updatedAppointments          Appointment[]          @relation("AppointmentUpdater")
  rescheduledAppointments      Appointment[]          @relation("AppointmentRescheduler")
  confirmedAppointments        Appointment[]          @relation("AppointmentConfirmer")
  cancelledAppointments        Appointment[]          @relation("AppointmentCanceller")
  completedAppointments        Appointment[]          @relation("AppointmentCompleter")
  appointmentActivities        AppointmentActivity[]  @relation("AppointmentActivityActorUser")
  businessNotifications        BusinessNotification[] @relation("BusinessNotificationRecipient")
  createdBusinessNotifications BusinessNotification[] @relation("BusinessNotificationCreator")
  customerIssueLogs            CustomerIssueLog[]     @relation("CustomerIssueActor")
}

model BusinessAccount {
  id        String   @id @default(cuid())
  name      String
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner         User                   @relation("BusinessAccountOwner", fields: [ownerId], references: [id])
  businesses    Business[]
  subscriptions Subscription[]
  usageRecords  AccountUsageRecord[]
  appointments  Appointment[]
  notifications BusinessNotification[]
  aiInteractionLogs AiInteractionLog[]

  @@index([ownerId])
}

model Business {
  id                          String                      @id @default(cuid())
  businessAccountId           String
  name                        String
  industry                    String
  description                 String?
  slug                        String                      @unique
  ownerId                     String
  email                       String?
  phone                       String?
  country                     String?
  city                        String?
  address                     String?
  serviceArea                 String?
  website                     String?
  timezone                    String                      @default("Africa/Accra")
  defaultCurrency             String                      @default("GHS")
  defaultNotificationEmail    String?
  appointmentConfirmationMode AppointmentConfirmationMode @default(MANUAL_CONFIRMATION_REQUIRED)
  aiRepliesEnabled            Boolean                     @default(true)
  aiAutoReplyEnabled          Boolean                     @default(true)
  aiHandoffOnLowConfidence    Boolean                     @default(true)
  aiTone                      AiTone                      @default(PROFESSIONAL)
  aiMinConfidence             Float?
  status                      BusinessStatus              @default(PENDING_SETUP)
  createdAt                   DateTime                    @default(now())
  updatedAt                   DateTime                    @updatedAt
  deletedAt                   DateTime?

  owner                 User                   @relation("BusinessOwner", fields: [ownerId], references: [id])
  businessAccount       BusinessAccount        @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  members               BusinessMember[]
  invitations           BusinessInvitation[]
  usageRecords          BusinessUsageRecord[]
  auditLogs             AuditLog[]
  leads                 Lead[]
  leadActivities        LeadActivity[]
  conversations         Conversation[]
  messages              Message[]
  whatsAppIntegrations  WhatsAppIntegration[]
  webhookEventLogs      WebhookEventLog[]
  aiInteractionLogs     AiInteractionLog[]
  services              Service[]
  availability          BusinessAvailability[]
  policies              BusinessPolicy[]
  appointments          Appointment[]
  appointmentActivities AppointmentActivity[]
  notifications         BusinessNotification[]
  customerIssueLogs     CustomerIssueLog[]

  @@index([ownerId])
  @@index([businessAccountId])
}

model Service {
  id                           String                 @id @default(cuid())
  businessId                   String
  name                         String
  slug                         String
  category                     String?
  description                  String?
  basePrice                    Decimal?               @db.Decimal(12, 2)
  currency                     String                 @default("GHS")
  priceType                    ServicePriceType       @default(NOT_SET)
  priceDescription             String?
  durationMinutes              Int?
  bufferMinutes                Int                    @default(0)
  requiresPayment              Boolean                @default(false)
  paymentRequiredBeforeBooking Boolean                @default(false)
  isBookable                   Boolean                @default(false)
  isActive                     Boolean                @default(true)
  isArchived                   Boolean                @default(false)
  readinessStatus              ServiceReadinessStatus @default(DRAFT)
  missingFields                String[]               @default([])
  displayOrder                 Int                    @default(0)
  source                       ServiceSource          @default(MANUAL)
  createdById                  String?
  updatedById                  String?
  createdAt                    DateTime               @default(now())
  updatedAt                    DateTime               @updatedAt
  archivedAt                   DateTime?

  business     Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy    User?         @relation("ServiceCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy    User?         @relation("ServiceUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  appointments Appointment[]

  @@index([businessId])
  @@index([businessId, isArchived])
  @@index([businessId, isActive])
  @@index([businessId, readinessStatus])
  @@index([businessId, name])
  @@index([businessId, slug])
}

model BusinessAvailability {
  id                   String    @id @default(cuid())
  businessId           String
  dayOfWeek            DayOfWeek
  isOpen               Boolean   @default(false)
  openTime             String?
  closeTime            String?
  breakStartTime       String?
  breakEndTime         String?
  timezone             String    @default("Africa/Accra")
  appliesToAllServices Boolean   @default(true)
  isActive             Boolean   @default(true)
  createdById          String?
  updatedById          String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("AvailabilityCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("AvailabilityUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@unique([businessId, dayOfWeek])
  @@index([businessId])
  @@index([businessId, isActive])
}

model BusinessPolicy {
  id           String                   @id @default(cuid())
  businessId   String
  title        String
  category     BusinessPolicyCategory   @default(GENERAL)
  content      String
  shortSummary String?
  visibility   BusinessPolicyVisibility @default(CUSTOMER_FACING)
  isActive     Boolean                  @default(true)
  isArchived   Boolean                  @default(false)
  displayOrder Int                      @default(0)
  priority     Int                      @default(0)
  source       BusinessPolicySource     @default(MANUAL)
  createdById  String?
  updatedById  String?
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  archivedAt   DateTime?

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdBy User?    @relation("PolicyCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User?    @relation("PolicyUpdater", fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([businessId])
  @@index([businessId, isArchived])
  @@index([businessId, isActive])
  @@index([businessId, category])
  @@index([businessId, visibility])
  @@index([businessId, displayOrder])
}

model BusinessMember {
  id                         String           @id @default(cuid())
  businessId                 String
  userId                     String
  role                       BusinessRole
  status                     MembershipStatus @default(ACTIVE)
  joinedAt                   DateTime?
  invitedById                String?
  disabledAt                 DateTime?
  disabledByMembershipId     String?
  disabledReason             String?
  removedAt                  DateTime?
  removedByMembershipId      String?
  removedReason              String?
  suspendedAt                DateTime?
  suspendedByMembershipId    String?
  suspendedReason            String?
  restoredAt                 DateTime?
  restoredByMembershipId     String?
  positionTitle              String?
  specialties                String[]         @default([])
  serviceTags                String[]         @default([])
  isAiHandoffEligible        Boolean          @default(true)
  aiHandoffPriority          Int?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  business                     Business               @relation(fields: [businessId], references: [id], onDelete: Cascade)
  user                         User                   @relation("MemberUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy                    User?                  @relation("MemberInviter", fields: [invitedById], references: [id], onDelete: SetNull)
  assignedLeads                Lead[]                 @relation("LeadAssignee")
  assignedConversations        Conversation[]         @relation("ConversationAssignee")
  assignedAppointments         Appointment[]          @relation("AppointmentAssignee")
  lastRescheduledAppointments  Appointment[]          @relation("AppointmentLastRescheduler")
  outcomeConfirmedAppointments Appointment[]          @relation("AppointmentOutcomeConfirmer")
  appointmentActivities        AppointmentActivity[]  @relation("AppointmentActivityActorMembership")
  notifications                BusinessNotification[]
  responsibleCustomerIssues    CustomerIssueLog[]     @relation("CustomerIssueResponsible")
  suggestedCustomerIssues      CustomerIssueLog[]     @relation("CustomerIssueSuggestedResponsible")
  clientOwnedCustomerIssues    CustomerIssueLog[]     @relation("CustomerIssueClientOwner")
  conversationAssignedCustomerIssues CustomerIssueLog[] @relation("CustomerIssueConversationAssignee")

  @@unique([businessId, userId])
  @@index([userId])
  @@index([businessId, status])
  @@index([invitedById])
  @@index([disabledByMembershipId])
  @@index([removedByMembershipId])
  @@index([suspendedByMembershipId])
}

model BusinessInvitation {
  id          String           @id @default(cuid())
  businessId  String
  email       String
  role        BusinessRole
  status      InvitationStatus @default(PENDING)
  tokenHash   String           @unique
  expiresAt   DateTime
  invitedById String
  acceptedByUserId String?
  acceptedAt  DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  business  Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy User     @relation("InvitationInviter", fields: [invitedById], references: [id], onDelete: Cascade)

  @@index([businessId, status])
  @@index([email, status])
  @@index([acceptedByUserId])
}

model Plan {
  id                       String   @id @default(cuid())
  name                     String
  code                     PlanCode @unique
  priceMonthly             Decimal  @db.Decimal(10, 2)
  currency                 String   @default("GHS")
  maxStaff                 Int?
  maxServices              Int?
  maxAppointmentsPerMonth  Int?
  maxConversationsPerMonth Int?
  maxAiRepliesPerMonth     Int?
  maxKnowledgeItems        Int?
  maxBusinesses            Int?
  allowAnalytics           Boolean  @default(false)
  allowRemoveBranding      Boolean  @default(false)
  allowPrioritySupport     Boolean  @default(false)
  isActive                 Boolean  @default(true)
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id                 String             @id @default(cuid())
  businessAccountId  String
  planId             String
  status             SubscriptionStatus @default(TRIALING)
  startsAt           DateTime           @default(now())
  trialEndsAt        DateTime?
  currentPeriodStart DateTime
  currentPeriodEnd   DateTime
  cancelledAt        DateTime?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  businessAccount BusinessAccount      @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  plan            Plan                 @relation(fields: [planId], references: [id])
  usageRecords    AccountUsageRecord[]

  @@index([businessAccountId, status])
}

model AccountUsageRecord {
  id                  String   @id @default(cuid())
  businessAccountId   String
  subscriptionId      String
  businessesCount     Int      @default(1)
  conversationsUsed   Int      @default(0)
  aiRepliesUsed       Int      @default(0)
  aiRequestsUsed      Int      @default(0)
  aiTokensUsed        Int      @default(0)
  aiBlockedUsed       Int      @default(0)
  aiHumanReviewsUsed  Int      @default(0)
  aiBookingRequestsCreated Int @default(0)
  aiSafeHandoffsTriggered Int @default(0)
  aiSafeHandoffEmailsSent Int @default(0)
  aiComplaintsDetected Int @default(0)
  customerIssuesLogged Int @default(0)
  customerIssuesRouted Int @default(0)
  customerIssueEmailsSent Int @default(0)
  staffCount          Int      @default(1)
  servicesCount       Int      @default(0)
  appointmentsUsed    Int      @default(0)
  knowledgeItemsCount Int      @default(0)
  periodStart         DateTime
  periodEnd           DateTime
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  businessAccount BusinessAccount @relation(fields: [businessAccountId], references: [id], onDelete: Cascade)
  subscription    Subscription    @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, periodStart])
  @@index([businessAccountId, periodStart])
}

model BusinessUsageRecord {
  id                String   @id @default(cuid())
  businessId        String
  conversationsUsed Int      @default(0)
  aiRepliesUsed     Int      @default(0)
  appointmentsUsed  Int      @default(0)
  leadsCreated      Int      @default(0)
  periodStart       DateTime
  periodEnd         DateTime
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@unique([businessId, periodStart])
  @@index([businessId, periodStart])
}

model AuthToken {
  id        String        @id @default(cuid())
  userId    String
  type      AuthTokenType
  tokenHash String        @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime      @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type])
}

model RefreshToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model AuditLog {
  id                String      @id @default(cuid())
  businessId        String?
  userId            String?
  actorMembershipId String?
  action            AuditAction
  metadata          Json?
  ipAddress         String?
  userAgent         String?
  createdAt         DateTime    @default(now())

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([userId, createdAt])
  @@index([actorMembershipId, createdAt])
}

model Lead {
  id              String     @id @default(cuid())
  businessId      String
  fullName        String
  phone           String
  email           String?
  source          LeadSource
  status          LeadStatus @default(NEW)
  assignedStaffId String?
  notes           String?
  tags            String[]   @default([])
  customFields    Json?
  lastContactedAt DateTime?
  createdById     String?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  deletedAt       DateTime?

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  assignedStaff BusinessMember? @relation("LeadAssignee", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  createdBy     User?           @relation("LeadCreator", fields: [createdById], references: [id], onDelete: SetNull)
  activities    LeadActivity[]
  conversations Conversation[]
  messages      Message[]
  appointments  Appointment[]
  customerIssueLogs CustomerIssueLog[]

  @@index([businessId])
  @@index([businessId, phone])
  @@index([businessId, status])
  @@index([businessId, source])
  @@index([businessId, assignedStaffId])
  @@index([businessId, createdAt])
  @@index([businessId, deletedAt])
}

model LeadActivity {
  id          String             @id @default(cuid())
  businessId  String
  leadId      String
  actorUserId String?
  action      LeadActivityAction
  metadata    Json?
  createdAt   DateTime           @default(now())

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  actor    User?    @relation("LeadActivityActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([businessId, leadId, createdAt])
  @@index([actorUserId, createdAt])
}

model Conversation {
  id                 String               @id @default(cuid())
  displayId          String               @unique @default(dbgenerated())
  businessId         String
  leadId             String
  assignedStaffId    String?
  channel            ConversationChannel
  status             ConversationStatus   @default(OPEN)
  subject            String?
  priority           ConversationPriority @default(NORMAL)
  pinned             Boolean              @default(false)
  lastMessagePreview String?
  lastMessageAt      DateTime?
  unreadCount        Int                  @default(0)
  aiEnabled          Boolean              @default(false)
  humanTakeover      Boolean              @default(false)
  needsHumanReview   Boolean              @default(false)
  humanReviewReason  String?
  humanReviewType    HumanReviewType?
  humanReviewCreatedAt DateTime?
  humanReviewResolvedAt DateTime?
  humanReviewResolvedByMembershipId String?
  lastAiBlockedReason String?
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  closedAt           DateTime?
  deletedAt          DateTime?

  business      Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lead          Lead            @relation(fields: [leadId], references: [id], onDelete: Cascade)
  assignedStaff BusinessMember? @relation("ConversationAssignee", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  messages      Message[]
  appointments  Appointment[]
  customerIssueLogs CustomerIssueLog[]
  aiInteractionLogs AiInteractionLog[]

  @@index([businessId])
  @@index([businessId, leadId])
  @@index([businessId, assignedStaffId])
  @@index([businessId, status])
  @@index([businessId, priority])
  @@index([businessId, pinned])
  @@index([businessId, channel])
  @@index([businessId, lastMessageAt])
  @@index([businessId, deletedAt])
  @@index([businessId, needsHumanReview])
  @@index([humanReviewResolvedByMembershipId])
}

model Message {
  id                String                @id @default(cuid())
  businessId        String
  conversationId    String
  leadId            String
  senderType        MessageSenderType
  senderUserId      String?
  content           String
  messageType       MessageType
  direction         MessageDirection
  deliveryStatus    MessageDeliveryStatus
  provider          String?
  providerMessageId String?
  metadata          Json?
  readAt            DateTime?
  createdAt         DateTime              @default(now())
  updatedAt         DateTime              @updatedAt
  deletedAt         DateTime?

  business     Business     @relation(fields: [businessId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lead         Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
  senderUser   User?        @relation("MessageSender", fields: [senderUserId], references: [id], onDelete: SetNull)
  sourceAiLogs AiInteractionLog[] @relation("AiInteractionSourceMessage")
  replyAiLogs  AiInteractionLog[] @relation("AiInteractionReplyMessage")
  customerIssueLogs CustomerIssueLog[]

  @@index([businessId])
  @@index([conversationId])
  @@index([businessId, conversationId])
  @@index([businessId, leadId])
  @@index([createdAt])
  @@index([senderType])
  @@index([deliveryStatus])
  @@index([businessId, provider, providerMessageId])
}

model CustomerIssueLog {
  id                               String                 @id @default(cuid())
  businessId                       String
  leadId                           String?
  conversationId                   String?
  customerMessageId                String?
  type                             CustomerIssueType
  category                         CustomerIssueCategory
  subcategory                      String?
  severity                         CustomerIssueSeverity
  summary                          String
  customerMessageExcerpt           String?
  clientOwnerMembershipId          String?
  conversationAssignedMembershipId String?
  suggestedResponsibleMembershipId String?
  responsibleMembershipId          String?
  routingReason                    String?
  status                           CustomerIssueStatus    @default(OPEN)
  createdBy                        CustomerIssueCreatedBy @default(AI)
  createdByUserId                  String?
  metadata                         Json?
  createdAt                        DateTime               @default(now())
  updatedAt                        DateTime               @updatedAt
  resolvedAt                       DateTime?

  business                   Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  lead                       Lead?           @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation               Conversation?   @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  customerMessage            Message?        @relation(fields: [customerMessageId], references: [id], onDelete: SetNull)
  clientOwner                BusinessMember? @relation("CustomerIssueClientOwner", fields: [clientOwnerMembershipId], references: [id], onDelete: SetNull)
  conversationAssignedMember BusinessMember? @relation("CustomerIssueConversationAssignee", fields: [conversationAssignedMembershipId], references: [id], onDelete: SetNull)
  suggestedResponsibleMember BusinessMember? @relation("CustomerIssueSuggestedResponsible", fields: [suggestedResponsibleMembershipId], references: [id], onDelete: SetNull)
  responsibleMember          BusinessMember? @relation("CustomerIssueResponsible", fields: [responsibleMembershipId], references: [id], onDelete: SetNull)
  createdByUser              User?           @relation("CustomerIssueActor", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([businessId, status, createdAt])
  @@index([businessId, category, createdAt])
  @@index([businessId, severity, createdAt])
  @@index([businessId, responsibleMembershipId, createdAt])
  @@index([businessId, leadId, createdAt])
  @@index([businessId, conversationId, createdAt])
  @@index([customerMessageId])
}

model AiInteractionLog {
  id                  String   @id @default(cuid())
  businessId          String
  businessAccountId   String?
  conversationId      String
  messageId           String
  aiMessageId         String?
  provider            String
  model               String
  primaryModel        String?
  finalModelUsed      String?
  fallbackAttempted   Boolean  @default(false)
  fallbackModelsTried Json?
  fallbackFailureReasons Json?
  providerRequestCount Int     @default(1)
  plan                PlanCode?
  quotaStatus         String?
  replySent           Boolean  @default(false)
  whatsappSendFailed  Boolean  @default(false)
  bookingRequestCreated Boolean @default(false)
  appointmentId       String?
  humanReviewNotificationCreated Boolean @default(false)
  intent              String?
  confidence          Float?
  suggestedAction     String?
  shouldReply         Boolean  @default(false)
  requiresHumanReview Boolean  @default(false)
  blockedReason       String?
  promptTokens        Int?
  completionTokens    Int?
  totalTokens         Int?
  latencyMs           Int
  status              String
  errorCode           String?
  createdAt           DateTime @default(now())

  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessAccount BusinessAccount? @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  conversation    Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sourceMessage   Message          @relation("AiInteractionSourceMessage", fields: [messageId], references: [id], onDelete: Cascade)
  aiMessage       Message?         @relation("AiInteractionReplyMessage", fields: [aiMessageId], references: [id], onDelete: SetNull)

  @@index([businessId, createdAt])
  @@index([businessAccountId, createdAt])
  @@index([conversationId, createdAt])
  @@index([messageId])
  @@index([aiMessageId])
  @@index([status, createdAt])
}

model WhatsAppIntegration {
  id                   String                    @id @default(cuid())
  businessId           String
  provider             WhatsAppProvider          @default(META)
  phoneNumberId        String
  displayPhoneNumber   String?
  wabaId               String?
  businessAccountId    String?
  accessTokenEncrypted String?
  verifyTokenHash      String?
  appSecretHash        String?
  status               WhatsAppIntegrationStatus @default(NOT_CONNECTED)
  automationEnabled    Boolean                   @default(false)
  connectedAt          DateTime?
  disconnectedAt       DateTime?
  deactivatedAt        DateTime?
  lastHealthCheckAt    DateTime?
  lastErrorCode        String?
  lastErrorMessage     String?
  metadata             Json?
  createdAt            DateTime                  @default(now())
  updatedAt            DateTime                  @updatedAt

  business Business @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([provider, phoneNumberId])
  @@index([phoneNumberId])
  @@index([businessId, status])
  @@index([businessId, createdAt])
}

model WebhookEventLog {
  id                String                  @id @default(cuid())
  provider          WebhookProvider
  eventType         WebhookEventType
  businessId        String?
  conversationId    String?
  messageId         String?
  providerMessageId String?
  payload           Json
  processingStatus  WebhookProcessingStatus @default(RECEIVED)
  errorMessage      String?
  receivedAt        DateTime                @default(now())
  processedAt       DateTime?

  business Business? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([provider, providerMessageId])
  @@index([businessId, receivedAt])
  @@index([conversationId, receivedAt])
  @@index([messageId, receivedAt])
  @@index([processingStatus, receivedAt])
}

model Appointment {
  id                        String                              @id @default(cuid())
  businessId                String
  businessAccountId         String?
  leadId                    String?
  conversationId            String?
  serviceId                 String?
  assignedStaffId           String?
  customerName              String?
  customerPhone             String?
  customerEmail             String?
  title                     String
  description               String?
  notes                     String?
  appointmentDate           DateTime
  startTime                 DateTime
  endTime                   DateTime
  timezone                  String
  status                    AppointmentStatus                   @default(CONFIRMED)
  source                    AppointmentSource                   @default(MANUAL)
  locationType              AppointmentLocationType             @default(TO_BE_CONFIRMED)
  location                  String?
  locationStatus            AppointmentLocationStatus           @default(NEEDS_CONFIRMATION)
  humanConfirmationRequired Boolean                             @default(false)
  humanConfirmationReason   AppointmentHumanConfirmationReason?
  cancellationReason        String?
  rescheduleReason          String?
  rescheduleCount           Int                                 @default(0)
  lastRescheduledById       String?
  outcomeConfirmedById      String?
  outcomeNote               String?
  missedReason              String?
  noShowReason              String?
  completedNote             String?
  createdById               String?
  updatedById               String?
  rescheduledById           String?
  confirmedById             String?
  cancelledById             String?
  completedById             String?
  createdAt                 DateTime                            @default(now())
  updatedAt                 DateTime                            @updatedAt
  rescheduledAt             DateTime?
  lastRescheduledAt         DateTime?
  confirmedAt               DateTime?
  cancelledAt               DateTime?
  completedAt               DateTime?
  outcomeRequiredAt         DateTime?
  outcomeConfirmedAt        DateTime?

  business           Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessAccount    BusinessAccount?      @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  lead               Lead?                 @relation(fields: [leadId], references: [id], onDelete: SetNull)
  conversation       Conversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  service            Service?              @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  assignedStaff      BusinessMember?       @relation("AppointmentAssignee", fields: [assignedStaffId], references: [id], onDelete: SetNull)
  lastRescheduledBy  BusinessMember?       @relation("AppointmentLastRescheduler", fields: [lastRescheduledById], references: [id], onDelete: SetNull)
  outcomeConfirmedBy BusinessMember?       @relation("AppointmentOutcomeConfirmer", fields: [outcomeConfirmedById], references: [id], onDelete: SetNull)
  createdBy          User?                 @relation("AppointmentCreator", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy          User?                 @relation("AppointmentUpdater", fields: [updatedById], references: [id], onDelete: SetNull)
  rescheduledBy      User?                 @relation("AppointmentRescheduler", fields: [rescheduledById], references: [id], onDelete: SetNull)
  confirmedBy        User?                 @relation("AppointmentConfirmer", fields: [confirmedById], references: [id], onDelete: SetNull)
  cancelledBy        User?                 @relation("AppointmentCanceller", fields: [cancelledById], references: [id], onDelete: SetNull)
  completedBy        User?                 @relation("AppointmentCompleter", fields: [completedById], references: [id], onDelete: SetNull)
  activities         AppointmentActivity[]

  @@index([businessId])
  @@index([businessAccountId])
  @@index([businessId, leadId])
  @@index([businessId, conversationId])
  @@index([businessId, serviceId])
  @@index([businessId, assignedStaffId])
  @@index([businessId, status])
  @@index([businessId, source])
  @@index([businessId, appointmentDate])
  @@index([businessId, startTime])
  @@index([businessId, startTime, endTime])
}

model AppointmentActivity {
  id                String                  @id @default(cuid())
  businessId        String
  appointmentId     String
  actorUserId       String?
  actorMembershipId String?
  type              AppointmentActivityType
  message           String
  metadata          Json?
  createdAt         DateTime                @default(now())

  business        Business        @relation(fields: [businessId], references: [id], onDelete: Cascade)
  appointment     Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  actorUser       User?           @relation("AppointmentActivityActorUser", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorMembership BusinessMember? @relation("AppointmentActivityActorMembership", fields: [actorMembershipId], references: [id], onDelete: SetNull)

  @@index([businessId, appointmentId, createdAt])
  @@index([actorUserId, createdAt])
  @@index([actorMembershipId, createdAt])
}

model BusinessNotification {
  id                    String                          @id @default(cuid())
  businessId            String
  businessAccountId     String?
  recipientMembershipId String
  recipientUserId       String
  createdById           String?
  type                  BusinessNotificationType
  priority              BusinessNotificationPriority    @default(NORMAL)
  status                BusinessNotificationStatus      @default(UNREAD)
  title                 String
  message               String
  entityType            BusinessNotificationEntityType?
  entityId              String?
  actions               Json?
  metadata              Json?
  readAt                DateTime?
  actionedAt            DateTime?
  dismissedAt           DateTime?
  expiresAt             DateTime?
  archivedAt            DateTime?
  createdAt             DateTime                        @default(now())
  updatedAt             DateTime                        @updatedAt

  business            Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  businessAccount     BusinessAccount? @relation(fields: [businessAccountId], references: [id], onDelete: SetNull)
  recipientMembership BusinessMember   @relation(fields: [recipientMembershipId], references: [id], onDelete: Cascade)
  recipientUser       User             @relation("BusinessNotificationRecipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  createdBy           User?            @relation("BusinessNotificationCreator", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([businessId, status, createdAt])
  @@index([recipientMembershipId, status, createdAt])
  @@index([recipientUserId, status, createdAt])
  @@index([businessId, type, createdAt])
  @@index([businessId, entityType, entityId])
  @@index([businessAccountId, createdAt])
}
